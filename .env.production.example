# =====================================================================
# NegocIA v2 - Variables de entorno para PRODUCCION (Railway + Vercel)
# =====================================================================
# Configurar en: Railway Dashboard > tu servicio > Variables
# NO commitear con valores reales

# --- Django Core ---
DEBUG=False
SECRET_KEY=<generar: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())">

# --- Base de datos (Railway la inyecta automaticamente al agregar PostgreSQL plugin) ---
DATABASE_URL=postgresql://postgres:password@containers-us-west-XXX.railway.app:7890/railway

# --- Hosts permitidos ---
ALLOWED_HOSTS=.railway.app,.up.railway.app

# --- CORS (URL de tu app Vercel) ---
CORS_ALLOWED_ORIGINS=https://TU-APP.vercel.app
FRONTEND_URL=https://TU-APP.vercel.app

# --- Cloudinary (logos de empresas, imagenes) ---
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret

# --- Email Gmail (App Password - NO tu password de Gmail normal) ---
# Como generar: Google Account > Seguridad > Verificacion 2 pasos > Contrasenas de app
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=pizzia.peru@gmail.com
EMAIL_HOST_PASSWORD=xxxx xxxx xxxx xxxx
DEFAULT_FROM_EMAIL=NegocIA <pizzia.peru@gmail.com>