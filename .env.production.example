# =====================================================================
# NegocIA v2 - Variables de entorno para PRODUCCION (Render + Vercel)
# =====================================================================
# IMPORTANTE: Nunca commitear este archivo con valores reales
# Copiar como .env y rellenar con valores reales

# --- Django Core ---
DEBUG=False
SECRET_KEY=<generar-con: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())">

# --- Base de datos (Render la genera automaticamente via render.yaml) ---
DATABASE_URL=postgresql://user:password@host.render.com:5432/negociav2

# --- Hosts permitidos ---
ALLOWED_HOSTS=negociav2-api.onrender.com,.onrender.com

# --- CORS (URL de tu app Vercel) ---
CORS_ALLOWED_ORIGINS=https://negociav2.vercel.app
FRONTEND_URL=https://negociav2.vercel.app

# --- Cloudinary (media files: logos de empresas, etc.) ---
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret

# --- Email (Gmail App Password) ---
# IMPORTANTE: No usar tu password de Gmail normal.
# Ir a: Google Account > Seguridad > Verificacion en 2 pasos > Contrasenas de aplicacion
# Crear una contrasena de app para "Correo > Windows/Otra"
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=pizzia.peru@gmail.com
EMAIL_HOST_PASSWORD=xxxx xxxx xxxx xxxx
DEFAULT_FROM_EMAIL=NegocIA <pizzia.peru@gmail.com>

# --- Tenant (cuando tengas dominio propio, cambiar) ---
# Por ahora dejar vacio o usar el subdominio de render
TENANT_BASE_DOMAIN=onrender.com