# =====================================================================
# NegocIA v2 Frontend - Variables de entorno para PRODUCCION (Vercel)
# =====================================================================
# Configurar estas variables en: Vercel Dashboard > Project > Settings > Environment Variables

# URL del backend Django en Render
# Reemplazar con la URL real asignada por Render
VITE_API_URL=https://negociav2-api.onrender.com

# Puerto del API (no necesario si VITE_API_URL incluye el host completo)
# VITE_API_PORT=443