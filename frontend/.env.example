# ═══════════════════════════════════════════════════════════════════
#  NegocIA SaaS — Variables de Entorno del FRONTEND (Vite)
#  Copia como:
#    frontend/.env              (desarrollo local)
#    frontend/.env.production   (producción — en CI/CD o Vercel/Netlify)
# ═══════════════════════════════════════════════════════════════════

# ── URL de la API pública (Landing: registro y buscar-tenant) ─────
# Desarrollo: la Landing usa localhost:8000 automáticamente si está vacío
# Producción: URL del backend Django (Railway, Render, etc.)
VITE_PUBLIC_API_URL=http://localhost:8000
# Producción: VITE_PUBLIC_API_URL=https://api.tudominio.com

# ── URL de la API para el tenant (subdominio) ─────────────────────
# En desarrollo: se detecta automáticamente desde window.location.hostname
# En producción: puede dejarse vacío (funciona igual) o forzarse
# VITE_API_URL=https://negocio.tudominio.com
VITE_API_PORT=8000

# ── Dominio raíz de la plataforma ─────────────────────────────────
# Desarrollo: localhost
# Producción: tudominio.com
VITE_ROOT_DOMAIN=localhost
# Producción: VITE_ROOT_DOMAIN=tudominio.com
