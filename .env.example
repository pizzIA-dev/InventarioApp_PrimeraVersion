# ═══════════════════════════════════════════════════════════════════
#  NegocIA SaaS — Variables de Entorno
#  Copia este archivo como .env y completa los valores
# ═══════════════════════════════════════════════════════════════════

# ── Seguridad ─────────────────────────────────────────────────────
# Genera con: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=django-insecure-CHANGE-THIS-IN-PRODUCTION

# Modo:  True=Desarrollo  |  False=Producción
DEBUG=True

# ── Hosts ─────────────────────────────────────────────────────────
# Desarrollo:
ALLOWED_HOSTS=localhost,127.0.0.1,.localhost,.nip.io
# Producción (añadir tu dominio):
# ALLOWED_HOSTS=localhost,127.0.0.1,.localhost,.nip.io,.tudominio.com,.onrender.com,.railway.app

# ── Dominio raíz de la plataforma ─────────────────────────────────
# Desarrollo: localhost   (genera subdomains como negocio.localhost)
# Producción: tudominio.com  (genera subdomains como negocio.tudominio.com)
BASE_DOMAIN=localhost

# URL pública del frontend (usada en emails de reset y bienvenida)
# Desarrollo: http://localhost:5175
# Producción: https://tudominio.com
FRONTEND_URL=http://localhost:5175

# ── Base de datos (desarrollo local con PostgreSQL) ───────────────
DB_NAME=inventario_saas
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=127.0.0.1
DB_PORT=5432

# ── Base de datos (producción — sobreescribe los individuales) ────
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── CORS ──────────────────────────────────────────────────────────
# En DEBUG=True: se usa CORS_ALLOW_ALL_ORIGINS=True (ignora esta lista)
# En DEBUG=False: SOLO estos orígenes están permitidos
CORS_ALLOWED_ORIGINS=http://localhost:5175,http://localhost:5173

# ── Cloudinary (almacenamiento de imágenes en producción) ─────────
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret

# ── Email (para reset de contraseña y bienvenida) ─────────────────
# En DEBUG=True: los emails se imprimen en la consola (no se necesita configurar)
# En DEBUG=False: se necesita un proveedor SMTP real
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=apikey
EMAIL_HOST_PASSWORD=tu-api-key-de-sendgrid
DEFAULT_FROM_EMAIL=noreply@tudominio.com
